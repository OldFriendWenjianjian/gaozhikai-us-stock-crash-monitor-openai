<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/main_eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPENAI EDITION"
            android:textColor="#E8C45C"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/main_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="高志凯美股崩盘概率预测程序"
            android:textColor="#F7F4ED"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/main_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="3dp"
            android:text="挂件会在每天早上 7:55 开始自动刷新当日预测结果。你不需要手动点开 App 才刷新。"
            android:textColor="#A7B0BA"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#131A22"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/hero_probability_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今日崩盘概率"
                android:textColor="#8E98A3"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/hero_probability"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="--"
                android:textColor="#F7F4ED"
                android:textSize="48sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/hero_stage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="等待刷新"
                android:textColor="#E8C45C"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/hero_trigger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:text="关键触发因素：等待数据"
                android:textColor="#D3DAE2"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/hero_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:text="等待服务端下发当天预测。"
                android:textColor="#A7B0BA"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/refresh_button"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="立即刷新" />

            <Button
                android:id="@+id/open_dashboard_button"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="打开完整面板" />
        </LinearLayout>

        <Button
            android:id="@+id/pin_widget_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="添加桌面挂件" />

        <TextView
            android:id="@+id/exact_alarm_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="为保证每天早上 7:55 准时刷新，请在系统中允许精确定时。"
            android:textColor="#E8C45C"
            android:textSize="13sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/exact_alarm_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="开启准时刷新"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#10161D"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="运行状态"
                android:textColor="#F7F4ED"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/main_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:text="等待同步"
                android:textColor="#A7B0BA"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
