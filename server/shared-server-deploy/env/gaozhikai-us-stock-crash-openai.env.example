# Shared server env for 高志凯美股崩盘概率预测程序（openai版）

TZ=Asia/Shanghai
NODE_ENV=production
NO_OPEN=1

# Local listen port for the Node service
PORT=3080

# Required for live collection
OPENAI_API_KEY=sk-your-real-key

# Optional if using a compatible gateway instead of official OpenAI
OPENAI_BASE_URL=

# Analysis model
OPENAI_ANALYSIS_MODEL=gpt-5.5

# Search model for web-search collection
OPENAI_SEARCH_MODEL=gpt-5.4-mini

# Optional runtime knobs
BASE_PATH=/us-stock-20260629/crash-monitor/
BASELINE=15
COLLECT_INTERVAL_MINUTES=0
